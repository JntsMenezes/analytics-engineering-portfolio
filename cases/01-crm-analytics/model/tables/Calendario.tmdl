	partition Calendario = m
		mode: import
		source =
				let
				    Fonte = Sql.Database("bi-db-server.internal", "bi_database", [Query="select * from dim_calendario with(Nolock)#(lf)where dt between '01-01-2025' and Getdate()"])
				in
				    Fonte

