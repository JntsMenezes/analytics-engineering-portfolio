	partition Clientes = m
		mode: import
		source =
				let
				    Fonte = Sql.Database("crm-db-server.internal", "crm_database", [Query="SELECT#(tab)#(lf)#(tab)A.*#(lf),CASE#(lf)#(tab) WHEN a.data_nascimento IS NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) THEN 'Não Informado'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE()) BETWEEN 18 AND 25 THEN '18-25'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE()) BETWEEN 26 AND 35 THEN '26-35'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE()) BETWEEN 36 AND 45 THEN '36-45'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE()) BETWEEN 46 AND 55 THEN '46-55'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE()) BETWEEN 56 AND 65 THEN '56-65'#(lf)     WHEN DATEDIFF(YEAR, A.DATA_NASCIMENTO, GETDATE())              < 18 THEN '-18'#(lf)#(tab) ELSE '66+'#(lf) END AS FAIXA_ETARIA #(lf)#(lf)#(lf)FROM dbo.clientes A WITH(NOLOCK)"]),
				    #"Data Inserida" = Table.AddColumn(Fonte, "Data", each Date.From([criado_em]), type date)
				in
				    #"Data Inserida"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação


