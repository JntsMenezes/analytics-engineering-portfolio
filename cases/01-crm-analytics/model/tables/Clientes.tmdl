table Clientes

	measure 'Faixa Etária + Ícone' = ```
			
			VAR Faixa = SELECTEDVALUE(Clientes[FAIXA_ETARIA])
			RETURN
			    SWITCH(
			        TRUE(),
			        Faixa = "Não Informado", "❓ " ,
			        Faixa = "-18", "🧒 " ,
			        Faixa = "18-25", "👦 " ,
			        Faixa = "26-35", "🧑 " ,
			        Faixa = "36-45", "👨‍💼 " ,
			        Faixa = "46-55", "👩‍🦳 " ,
			        Faixa = "56-65", "🧓 " ,
			        Faixa = "66+", "👴 " ,
			        "❓ " 
			    )
			
			```

	measure 'Linha Y Cadastro de produtos' = ```
			
			
			CALCULATE(
			DISTINCTCOUNT(Clientes[cpf]) 
			,ALL(Clientes))
			
			```
		formatString: 0

	measure 'cpf.' =
			
			VAR FILTRO = SELECTEDVALUE(CUPONS_IDENTIFICADOS[LOJA])
			RETURN
			IF(
			    NOT ISBLANK(FILTRO),
			    CALCULATE(DISTINCTCOUNT(Clientes[cpf]), Clientes[loja] = FILTRO),
			    DISTINCTCOUNT(Clientes[cpf])
			)
		formatString: 0

