	partition CUPONS_IDENTIFICADOS = m
		mode: import
		source =
				let
				    Fonte = Sql.Database("analytics-db-server.internal", "analytics_database", [Query="#(lf)#(lf)SELECT A.*,B.PERFIL FROM dbo.IMPORT_CRM_CUPONS_IDENTIFICADOS a WITH(NOLOCK)#(lf)LEFT JOIN dbo.CRM_HISTORICO_PERFIL_CLIENTE b WITH(NOLOCK) ON B.CPF = A.INSCRICAO_FEDERAL AND A.MOVIMENTO BETWEEN B.INICIO AND B.FIM#(lf)WHERE a.MOVIMENTO >= '01-01-2025'#(lf)#(lf)", CommandTimeout=#duration(0, 0, 40, 0)])
				in
				    Fonte

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table


